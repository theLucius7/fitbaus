# Linux 下建议让容器直接以宿主机用户运行，避免 bind mount 权限问题
FITBAUS_UID=1000
FITBAUS_GID=1000

# 对外监听地址；如果要接入 Caddy/Nginx，建议改成 127.0.0.1
FITBAUS_BIND_HOST=0.0.0.0

# 对外端口
FITBAUS_PORT=19000

# 容器时区（可按需调整）
TZ=Asia/Shanghai

# 如需显式指定 Fitbit 开发者应用凭据，可取消注释
# FITBIT_CLIENT_ID=your_client_id
# FITBIT_CLIENT_SECRET=your_client_secret

# 如需本地 HTTPS OAuth 回调，可按需取消注释
# FITBIT_REDIRECT_URI=http://localhost:8080/callback
# FITBIT_SSL_CERT=/certs/cert.pem
# FITBIT_SSL_KEY=/certs/key.pem
